.PHONY: dev seed down reset clean

# docker-compose.yml lives in the project root — delegate everything up.
# You can also run these targets from the project root directly.

dev:
	$(MAKE) -C .. dev

seed:
	$(MAKE) -C .. seed

down:
	$(MAKE) -C .. down

reset:
	$(MAKE) -C .. reset

clean:
	$(MAKE) -C .. clean
